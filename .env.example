# Copy this to .env and fill in. The .env is sourced by every script.
# Keep .env out of git (see .gitignore).

# === AWS ===
export AWS_REGION="ap-northeast-1"
export AWS_PROFILE="immich-backup"
export S3_BUCKET="my-immich-backup-CHANGEME"   # globally unique

# === GitHub (auto-deploy via self-hosted runner) ===
export GITHUB_REPO="s-tutti/immich-backup-s3"
# GITHUB_RUNNER_TOKEN is one-shot, only needed during 04_install_github_runner.sh
# Get it at: https://github.com/<owner>/<repo>/settings/actions/runners/new

# === Local paths ===
export UPLOAD_LOCATION="/mnt/hdd1"
export COMPOSE_DIR="/home/tutti/immich"
export TMPDIR="/mnt/hdd1/.backup_tmp"
export SNAPSHOT_DIR="/mnt/hdd1/.backup_state"

# === IAM Roles Anywhere (filled in after AWS setup steps 03 / 04) ===
export ROLE_ARN=""
export TRUST_ANCHOR_ARN=""
export PROFILE_ARN=""

# === Client cert (used by aws_signing_helper) ===
export CERT_PATH="/etc/aws/cert.pem"
export KEY_PATH="/etc/aws/key.pem"
# CA cert that you registered as the Trust Anchor:
export CA_CERT_PATH="/etc/aws/ca-cert.pem"

# === Slack ===
export SLACK_WEBHOOK_URL=""

# === Backup parameters ===
export PARALLEL=2
export CHUNK_SIZE_MB=102400      # 100 GiB per chunk
export RETENTION_DAYS=190        # Old-full deletion buffer (180 + 10)

# === Postgres (running inside the Immich Docker stack) ===
export PG_CONTAINER="immich_postgres"
export PG_USER="postgres"
